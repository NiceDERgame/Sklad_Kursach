<Page x:Class="Sklad_Kursach.Pages.Sort_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сортировка" Loaded="Page_Loaded">

    <Grid Background="{StaticResource BrushBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="40,40,40,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="⬅" Width="50" Height="50" Margin="0,0,20,0" 
                        Style="{StaticResource BtnStyle}" Click="Back_Click" FontSize="24" Padding="0,0,0,4"/>

                <TextBlock Text="🗂" FontSize="32" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="СОРТИРОВКА" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushPrimaryDark}"/>
                    <TextBlock x:Name="ProductTitle" Text="Выберите ячейку для товара" FontSize="14" Foreground="{StaticResource BrushTextSecondary}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="ZonesContainer" Margin="40,0,40,40">
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>