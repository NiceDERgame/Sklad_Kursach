<Page x:Class="Sklad_Kursach.Pages.AdminHubPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель Администратора"
      Loaded="Page_Loaded"
      d:DesignHeight="720"
      d:DesignWidth="1280"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid Background="{StaticResource BrushBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="⮌ Выйти"
                    Width="120"
                    Height="42"
                    Background="#D93636"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Logout_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BF2B2B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    Click="GoProfile"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Мой профиль"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimary}"/>
                    <Border x:Name="AvatarBorder"
                            Width="42"
                            Height="42"
                            CornerRadius="21"
                            Background="{StaticResource BrushPrimary}">
                        <TextBlock x:Name="AvatarEmoji"
                                   Text="👤"
                                   Foreground="White"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Заголовок -->
        <Border Grid.Row="1"
                Margin="24,0,24,16"
                Padding="0,6,0,20"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="АДМИНИСТРИРОВАНИЕ СКЛАДА"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimaryDark}"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,0,24,24">

            <StackPanel HorizontalAlignment="Center" MaxWidth="1220">

                <!-- Карточки статистики -->
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Margin="10" Padding="24" Background="White" CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Всего позиций" Foreground="#78909C" FontSize="15"/>
                            <TextBlock x:Name="TotalItemsTb"
                                       Text="0"
                                       Margin="0,14,0,0"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrushPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="10" Padding="24" Background="White" CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Принято сегодня" Foreground="#78909C" FontSize="15"/>
                            <TextBlock x:Name="NewItemsTb"
                                       Text="0"
                                       Margin="0,14,0,0"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#00ACC1"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="10" Padding="24" Background="White" CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Принято" Foreground="#78909C" FontSize="15"/>
                            <TextBlock Text="-"
                                       Margin="0,14,0,0"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#388E3C"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="10"
                            Padding="24"
                            Background="White"
                            CornerRadius="14"
                            BorderBrush="#E53935"
                            BorderThickness="1.5">
                        <StackPanel>
                            <TextBlock Text="Истекает срок (3 дня)"
                                       Foreground="#E53935"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="UrgentItemsTb"
                                       Text="0"
                                       Margin="0,14,0,0"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#E53935"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="10" Padding="24" Background="White" CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Отсортировано сегодня" Foreground="#78909C" FontSize="15"/>
                            <TextBlock x:Name="SortedItemsTb"
                                       Text="0"
                                       Margin="0,14,0,0"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#F2B01E"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="10" Padding="24" Background="White" CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Отгружено" Foreground="#78909C" FontSize="15"/>
                            <TextBlock Text="-"
                                       Margin="0,14,0,0"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#1976D2"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Кнопки -->
                <TextBlock Text="Управление"
                           Margin="10,0,10,14"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="Black"/>

                <UniformGrid Columns="4" Margin="0,0,0,10">
                    <Button Margin="10"
                            Height="138"
                            Style="{StaticResource BtnStyle}"
                            Click="GoInventory">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="34" HorizontalAlignment="Center"/>
                            <TextBlock Text="Склад"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Margin="10"
                            Height="138"
                            Style="{StaticResource BtnStyle}"
                            Click="GoLogs">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📜" FontSize="34" HorizontalAlignment="Center"/>
                            <TextBlock Text="Логи"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Margin="10"
                            Height="138"
                            Style="{StaticResource BtnStyle}"
                            Click="GoIncoming">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📥" FontSize="34" HorizontalAlignment="Center"/>
                            <TextBlock Text="Приём"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="10"
                            Height="138"
                            Style="{StaticResource BtnStyle}"
                            Click="GoWorkers">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👷" FontSize="34" HorizontalAlignment="Center"/>
                            <TextBlock Text="Рабочие"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>